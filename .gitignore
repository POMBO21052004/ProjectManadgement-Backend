# =============================================================================
#  .gitignore — Fichiers à NE PAS committer sur Git
# =============================================================================

# ─── Secrets ─────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.Python

# ─── Environnements virtuels ─────────────────────────────────────────────────
venv/
venv2/
env/
.venv/

# ─── Django ──────────────────────────────────────────────────────────────────
# db.sqlite3
db.sqlite3-journal
*.log
media/
staticfiles/
static/

# ─── IDE / OS ─────────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
Thumbs.db

# =============================================================================
#  .env.example — Copiez ce fichier en .env et remplissez les valeurs
#  NE PAS committer le fichier .env sur Git !
# =============================================================================

# ─── Django ──────────────────────────────────────────────────────────────────
# DEBUG=1  → développement local  (SQLite automatique, logs détaillés)
# DEBUG=0  → production            (PostgreSQL via DATABASE_URL, sécurité renforcée)
DEBUG=1

# Clé secrète Django — générer une clé unique pour la prod :
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=changez-moi-avec-une-vraie-cle-secrete

# Hôtes autorisés (séparés par des espaces) — en prod, mettre votre domaine
ALLOWED_HOSTS=localhost 127.0.0.1 [::1]

# ─── Base de données ─────────────────────────────────────────────────────────
# DEV  : Laisser DATABASE_URL commenté → SQLite utilisé automatiquement
# PROD : Décommenter et remplir avec l'URL PostgreSQL de votre hébergeur
#
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
#
# Exemples par hébergeur :
#   Render   → DATABASE_URL=postgresql://user:pass@oregon-postgres.render.com/mydb
#   Railway  → DATABASE_URL=postgresql://user:pass@monorail.proxy.rlwy.net:PORT/mydb
#   Supabase → DATABASE_URL=postgresql://postgres:pass@db.xxxx.supabase.co:5432/postgres
#   Neon     → DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/mydb

# ─── IA — Groq ───────────────────────────────────────────────────────────────
# Obtenez votre clé sur https://console.groq.com/keys
GROQ_API_KEY=votre_cle_groq_ici

# ─── Email (SMTP Gmail) ───────────────────────────────────────────────────────
# Pour Gmail, activer "Mot de passe d'application" sur votre compte Google :
# https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=votre.email@gmail.com
EMAIL_HOST_PASSWORD=votre_mot_de_passe_application

# ─── CORS (Production) ───────────────────────────────────────────────────────
# URL du frontend en production (laisser vide en dev)
# CORS_ALLOWED_ORIGIN_PROD=https://votre-frontend.vercel.app
